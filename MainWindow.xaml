<Window x:Class="PressureEmulationWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PressureEmulationWPF"
        xmlns:rules="clr-namespace:PressureEmulationWPF.View"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="647" Width="899">

    <Window.Resources>
        <ControlTemplate x:Key="validationTemplate">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="Red" BorderThickness="2">
                    <AdornedElementPlaceholder />
                </Border>
                <TextBlock Foreground="Red" FontSize="14" FontWeight="Bold">!</TextBlock>
            </StackPanel>
        </ControlTemplate>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self},
                    Path=(Validation.Errors)[0].ErrorContent}" />
                    <Setter Property="Foreground" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <TabControl>
            <TabItem x:Name="EmulationTab" Header="Эмуляция" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="370*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="56*"/>
                        <ColumnDefinition Width="353*"/>
                    </Grid.ColumnDefinitions>
                    <Button 
                        x:Name="StartButton" 
                        Content="Старт" 
                        HorizontalAlignment="Left" 
                        Margin="10,220,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="120"
                        Click="StartButton_Click"/>
                    <Button 
                        x:Name="StopButton" 
                        Content="Стоп" 
                        HorizontalAlignment="Left" 
                        Margin="10,255,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" 
                        Width="120"
                        Command="{Binding StopCommand}"/>
                    <RadioButton 
                        x:Name="ConstantPressureMode" 
                        Content="Постоянное давление" 
                        HorizontalAlignment="Left" 
                        Margin="10,14,0,0" 
                        VerticalAlignment="Top" 
                        FontSize="12" 
                        GroupName="PressureMode"
                        IsChecked="{Binding ConstantPressureMode}"/>
                    <lvc:CartesianChart
                        Series="{Binding Series}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"
                        x:Name="ETEmulationChart" 
                        Margin="185,10,10,10" 
                        Background="White" 
                        BorderBrush="Black" Grid.ColumnSpan="4"/>
                    <TextBox 
                        x:Name="ConstantPressureValue" 
                        HorizontalAlignment="Left" 
                        Margin="10,67,0,0" 
                        TextWrapping="Wrap"
                        VerticalAlignment="Top" 
                        Width="120"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20">
                        <TextBox.Text>
                            <Binding Path="ConstantPressureValue"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:PositiveDoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox 
                        x:Name="PressureDelta" 
                        HorizontalAlignment="Left" 
                        Margin="10,195,0,0" 
                        TextWrapping="Wrap"
                        VerticalAlignment="Top" 
                        Width="120"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20">
                        <TextBox.Text>
                            <Binding Path="PressureDelta"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:DoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Label Content="Шаг изменения давления" HorizontalAlignment="Left" Margin="10,168,0,0" VerticalAlignment="Top" Width="155" FontSize="10"/>
                    <TextBlock HorizontalAlignment="Left" Margin="10,33,0,0" TextWrapping="Wrap" Text="Величина постоянного давления" VerticalAlignment="Top" Height="29" Width="128" FontSize="10"/>
                    <RadioButton 
                        x:Name="ConstantChangingPressureMode" 
                        Content="Раст./Убыв. давление" 
                        HorizontalAlignment="Left" 
                        Margin="10,92,0,0" 
                        VerticalAlignment="Top" 
                        FontSize="12" 
                        GroupName="PressureMode"
                        IsChecked="{Binding ConstantChangingPressureMode}" Height="19" Width="170"/>
                    <TextBox 
                        x:Name="StartPressureValue" 
                        HorizontalAlignment="Left" 
                        Margin="10,143,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="120"    
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20">
                        <TextBox.Text>
                            <Binding Path="StartPressureValue"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:PositiveDoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Label Content="Стартовое значение давления" HorizontalAlignment="Left" Margin="10,116,0,0" VerticalAlignment="Top" Width="170" FontSize="10"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="SaveLastEmulationTab" Header="Сохранить последнюю эмуляцию" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <Button 
                        x:Name="SaveLastEmulation" 
                        Content="Сохранить последнюю эмуляцию" 
                        HorizontalAlignment="Left" 
                        Margin="10,127,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="205"
                        FontSize="10" 
                        Click="SaveLastEmulation_Click"/>
                    <TextBox 
                        x:Name="EmulationName" 
                        HorizontalAlignment="Left" 
                        Margin="10,10,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="205"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20">
                        <TextBox.Text>
                            <Binding Path="EmulationName"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:EmulationNameRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox 
                        x:Name="EmulationDate" 
                        HorizontalAlignment="Left" 
                        Margin="10,35,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="205"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20">
                        <TextBox.Text>
                            <Binding Path="EmulationDate" NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:DateTimeValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox HorizontalAlignment="Left" Margin="10,60,0,0" TextWrapping="Wrap" Text="Образец для ввода даты и времени &quot;4/15/2026 7:53:52 PM&quot;" VerticalAlignment="Top" Width="205" Height="62" IsReadOnly="True" Background="Transparent" BorderBrush="#00ABADB8"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="WatchSavedEmulationTab" Header="Просмотр сохранённых эмуляций" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <lvc:CartesianChart
                        Series="{Binding SeriesWSE}"
                        XAxes="{Binding XAxesWSE}"
                        YAxes="{Binding YAxesWSE}"
                        x:Name="WSEEmulationChart" 
                        Margin="281,10,10,10" 
                        Background="White" 
                        BorderBrush="Black"
                        ZoomMode="Both"/>
                    <Button 
                        x:Name="DrawGraphButton" 
                        Content="Отобразить график" 
                        HorizontalAlignment="Left" 
                        Margin="10,10,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="151"
                        Command="{Binding DrawGraphCommand}"/>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="10,45,0,10" Width="266" HorizontalAlignment="Left">
                        <DataGrid
                            ItemsSource="{Binding Emulations}"
                            AutoGenerateColumns="False"
                            SelectedItem="{Binding SelectedEmulation}"
                            SelectionMode="Single" 
                            IsReadOnly="True" FontSize="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Name"
                                    Binding="{Binding Name}"/>
                                <DataGridTextColumn 
                                    Header="Date"
                                    Binding="{Binding Date}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem x:Name="ModbusSlaveTab" HorizontalAlignment="Center" Height="21" Header="Modbus slave" VerticalAlignment="Top" Width="108" FontFamily="Verdana" FontSize="14" Margin="0,-1,0,0">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.5*"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox 
                        x:Name="SlaveIP" 
                        HorizontalAlignment="Left" 
                        Margin="10,40,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20" Grid.RowSpan="2">
                        <Binding Path="SlaveIP"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:IPRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBox 
                        x:Name="SlavePort" 
                        HorizontalAlignment="Left" 
                        Margin="10,95,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20" Grid.RowSpan="2">
                        <Binding Path="SlavePort"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:PortRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBox 
                        x:Name="SlaveID" 
                        HorizontalAlignment="Left" 
                        Margin="10,150,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20" Grid.RowSpan="2">
                        <Binding Path="SlaveID"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:SlaveIDRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <Label Content="IP" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="155" FontSize="12" Grid.RowSpan="2"/>
                    <Label Content="Port" HorizontalAlignment="Left" Margin="10,65,0,0" VerticalAlignment="Top" Width="155" FontSize="12" Grid.RowSpan="2"/>
                    <Label Content="SlaveID" HorizontalAlignment="Left" Margin="10,120,0,0" VerticalAlignment="Top" Width="155" FontSize="12" Grid.RowSpan="2"/>
                    <lvc:CartesianChart
                        Series="{Binding SeriesMS}"
                        XAxes="{Binding XAxesMS}"
                        YAxes="{Binding YAxesMS}"
                        x:Name="MSChart" 
                        Margin="10,10,10,10" 
                        Background="White" 
                        BorderBrush="Black" Grid.Column="1" Grid.ColumnSpan="2"/>
                    <Button 
                        x:Name="MSConnectButton" 
                        Content="Подключиться" 
                        HorizontalAlignment="Left" 
                        Margin="10,458,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="120" Click="MSConnectButton_Click" Grid.RowSpan="2"/>
                    <TextBox 
                        x:Name="InputRegisterAddress" 
                        HorizontalAlignment="Left" 
                        Margin="10,227,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20" Grid.RowSpan="2">
                        <Binding Path="InputRegisterAddress"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:InputRegisterAddressRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBlock HorizontalAlignment="Left" Margin="10,175,0,0" TextWrapping="Wrap" Text="Адрес Input регистра, откуда брать значения (double) для графика" VerticalAlignment="Top" Height="47" Width="147" FontSize="12" Grid.RowSpan="2"/>
                    <ComboBox 
                        x:Name="RegisterTypes" 
                        HorizontalAlignment="Left" 
                        Margin="10,282,0,0" 
                        VerticalAlignment="Top" 
                        Width="147"
                        ItemsSource="{Binding RegisterTypes}"
                        SelectedItem="{Binding SelectedRegisterType}" SelectedIndex="0" Grid.RowSpan="2">
                    </ComboBox>
                    <ComboBox 
                        x:Name="ValueTypes" 
                        HorizontalAlignment="Left" 
                        Margin="10,340,0,0"                          
                        VerticalAlignment="Top"                               
                        Width="147"                              
                        ItemsSource="{Binding ValueTypes}"                                
                        SelectedItem="{Binding SelectedValueType}" SelectedIndex="0" Grid.RowSpan="2">
                    </ComboBox>
                    <TextBox 
                        x:Name="Count" 
                        HorizontalAlignment="Left" 
                        Margin="10,395,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="ShowErrorMessage" Height="20" Grid.RowSpan="2">
                        <Binding Path="Count"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:CountRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <Border BorderBrush="Black" BorderThickness="1" Grid.Row="1" Grid.Column="2" Margin="10,10,10,38">
                        <DataGrid
                            ItemsSource="{Binding MSRegisterValues}"
                            AutoGenerateColumns="False"
                            IsReadOnly="True" 
                            FontSize="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Address"
                                    Binding="{Binding Address}"/>
                                <DataGridTextColumn 
                                    Header="RegisterValue"
                                    Binding="{Binding RegisterValue}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    <Label Content="Тип регистров" HorizontalAlignment="Left" Margin="10,252,0,0" VerticalAlignment="Top" Width="155" FontSize="12" Grid.RowSpan="2"/>

                    <Label Margin="10,310,0,0" Width="155" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="12" Content="Тип переменных" Grid.RowSpan="2"/>
                    <Label Margin="10,368,0,0" Width="147" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="10" Content="Число строк для вывода" Grid.RowSpan="2"/>
                    <Button Width="120" VerticalAlignment="Top" x:Name="MSDisconnectButton" Margin="10,493,0,0" Height="30" HorizontalAlignment="Left" Content="Отключиться" Click="MSDisconnectButton_Click" Grid.RowSpan="2"/>
                    <Label Margin="10,10,0,0" Width="147" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="14" Content="Макс. давление" Grid.Row="1" Grid.Column="1"/>
                    <Label Margin="10,70,0,0" Width="160" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="14" Content="Среднее. давление" Grid.Row="1" Grid.Column="1"/>
                    <Label Margin="10,130,0,0" Width="147" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="14" Content="Мин. давление" Grid.Row="1" Grid.Column="1"/>
                    <TextBlock 
                        x:Name="MSMaxPressure" 
                        HorizontalAlignment="Left" 
                        Margin="10,42,0,0" 
                        TextWrapping="Wrap" 
                        Text="{Binding MSMaxPressure}" 
                        VerticalAlignment="Top" 
                        Width="160" 
                        Height="23" Grid.Column="1" Grid.Row="1"/>
                    <TextBlock 
                        x:Name="MSAveragePressure" 
                        HorizontalAlignment="Left" 
                        Margin="10,102,0,0" 
                        TextWrapping="Wrap" 
                        Text="{Binding MSAveragePressure}" 
                        VerticalAlignment="Top" 
                        Width="160" 
                        Height="23" Grid.Row="1" Grid.Column="1"/>
                    <TextBlock 
                        x:Name="MSMinPressure" 
                        HorizontalAlignment="Left" 
                        Margin="10,162,0,0" 
                        TextWrapping="Wrap" 
                        Text="{Binding MSMinPressure}" 
                        VerticalAlignment="Top" 
                        Width="160" 
                        Height="23" Grid.Row="1" Grid.Column="1"/>
                    <CheckBox 
                        IsChecked="{Binding IsBigEndian}"
                        Content="IsBigEndian?" 
                        HorizontalAlignment="Left" 
                        Margin="10,427,0,0" 
                        VerticalAlignment="Top" Grid.RowSpan="2"/>
                    <StatusBar FontFamily="Verdana" FontSize="14" Height="28" VerticalAlignment="Bottom" Grid.Row="1" Grid.ColumnSpan="3">
                        <StatusBarItem>
                            <TextBlock Text="Статус подключения -"/>
                        </StatusBarItem>
                        <StatusBarItem>
                            <TextBlock Text="{Binding StatusText}"/>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

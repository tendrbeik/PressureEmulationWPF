<Window x:Class="PressureEmulationWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PressureEmulationWPF"
        xmlns:rules="clr-namespace:PressureEmulationWPF.View.ValidationRules"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">

    <Window.Resources>
        <ControlTemplate x:Key="validationTemplate">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="Red" BorderThickness="2">
                    <AdornedElementPlaceholder />
                </Border>
                <TextBlock Foreground="Red" FontSize="14" FontWeight="Bold">!</TextBlock>
            </StackPanel>
        </ControlTemplate>
        <Style TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip"
                Value="{Binding RelativeSource={RelativeSource Self},
                    Path=(Validation.Errors)[0].ErrorContent}" />
                    <Setter Property="Foreground" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <TabControl>
            <TabItem x:Name="EmulationTab" Header="Эмуляция" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="370*"/>
                        <ColumnDefinition Width="15*"/>
                        <ColumnDefinition Width="56*"/>
                        <ColumnDefinition Width="353*"/>
                    </Grid.ColumnDefinitions>
                    <Button 
                        x:Name="StartButton" 
                        Content="Старт" 
                        HorizontalAlignment="Left" 
                        Margin="10,287,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="120"
                        Click="StartButton_Click"/>
                    <Button 
                        x:Name="StopButton" 
                        Content="Стоп" 
                        HorizontalAlignment="Left" 
                        Margin="10,322,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" 
                        Width="120"
                        Command="{Binding StopCommand}"/>
                    <TextBox
                        x:Name="UpperPressureLimit" 
                        HorizontalAlignment="Left" 
                        Margin="10,56,0,0" 
                        VerticalAlignment="Top" 
                        Width="120" 
                        FontFamily="Verdana" 
                        FontSize="14" 
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error"
                        AutomationProperties.HelpText="Верхний предел давления задаётся числом с плавающей точкой. Пример - &quot;19.3&quot;." Height="20">
                        <TextBox.Text>
                            <Binding Path="UpperPressureLimit" 
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:PositiveDoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <RadioButton 
                        x:Name="ConstantPressureMode" 
                        Content="Постоянное давление" 
                        HorizontalAlignment="Left" 
                        Margin="10,81,0,0" 
                        VerticalAlignment="Top" 
                        FontSize="12" 
                        GroupName="PressureMode"
                        IsChecked="{Binding ConstantPressureMode}"/>
                    <RadioButton 
                        x:Name="RandomPressureMode" 
                        Content="Случайное давление" 
                        HorizontalAlignment="Left"
                        Margin="10,10,0,0" 
                        VerticalAlignment="Top" 
                        FontSize="12" 
                        GroupName="PressureMode" 
                        IsChecked="{Binding RandomPressureMode}"/>
                    <lvc:CartesianChart
                        Series="{Binding Series}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"
                        x:Name="ETEmulationChart" 
                        Margin="185,10,10,10" 
                        Background="White" 
                        BorderBrush="Black" Grid.ColumnSpan="4"/>
                    <Label Content="Верхний предел давления" HorizontalAlignment="Left" Margin="10,29,0,0" VerticalAlignment="Top" Width="155" FontSize="10"/>
                    <TextBox 
                        x:Name="ConstantPressureValue" 
                        HorizontalAlignment="Left" 
                        Margin="10,134,0,0" 
                        TextWrapping="Wrap"
                        VerticalAlignment="Top" 
                        Width="120"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <TextBox.Text>
                            <Binding Path="ConstantPressureValue"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:PositiveDoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox 
                        x:Name="PressureDelta" 
                        HorizontalAlignment="Left" 
                        Margin="10,262,0,0" 
                        TextWrapping="Wrap"
                        VerticalAlignment="Top" 
                        Width="120"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <TextBox.Text>
                            <Binding Path="PressureDelta"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:DoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Label Content="Шаг изменения давления" HorizontalAlignment="Left" Margin="10,235,0,0" VerticalAlignment="Top" Width="155" FontSize="10"/>
                    <TextBlock HorizontalAlignment="Left" Margin="10,100,0,0" TextWrapping="Wrap" Text="Величина постоянного давления" VerticalAlignment="Top" Height="29" Width="128" FontSize="10"/>
                    <RadioButton 
                        x:Name="ConstantChangingPressureMode" 
                        Content="Раст./Убыв. давление" 
                        HorizontalAlignment="Left" 
                        Margin="10,159,0,0" 
                        VerticalAlignment="Top" 
                        FontSize="12" 
                        GroupName="PressureMode"
                        IsChecked="{Binding ConstantChangingPressureMode}" Height="19" Width="170"/>
                    <TextBox 
                        x:Name="StartPressureValue" 
                        HorizontalAlignment="Left" 
                        Margin="10,210,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="120"    
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <TextBox.Text>
                            <Binding Path="StartPressureValue"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:PositiveDoubleValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Label Content="Стартовое значение давления" HorizontalAlignment="Left" Margin="10,183,0,0" VerticalAlignment="Top" Width="170" FontSize="10"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="SaveLastEmulationTab" Header="Сохранить последнюю эмуляцию" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <Button 
                        x:Name="SaveLastEmulation" 
                        Content="Сохранить последнюю эмуляцию" 
                        HorizontalAlignment="Left" 
                        Margin="10,127,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="205"
                        FontSize="10" 
                        Click="SaveLastEmulation_Click"/>
                    <TextBox 
                        x:Name="EmulationName" 
                        HorizontalAlignment="Left" 
                        Margin="10,10,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="205"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <TextBox.Text>
                            <Binding Path="EmulationName"
                                     NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:EmulationNameRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox 
                        x:Name="EmulationDate" 
                        HorizontalAlignment="Left" 
                        Margin="10,35,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="205"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <TextBox.Text>
                            <Binding Path="EmulationDate" NotifyOnValidationError="True">
                                <Binding.ValidationRules>
                                    <rules:DateTimeValueRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <TextBox HorizontalAlignment="Left" Margin="10,60,0,0" TextWrapping="Wrap" Text="Образец для ввода даты и времени &quot;4/15/2026 7:53:52 PM&quot;" VerticalAlignment="Top" Width="205" Height="62" IsReadOnly="True" Background="Transparent" BorderBrush="#00ABADB8"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="WatchSavedEmulationTab" Header="Просмотр сохранённых эмуляций" FontFamily="Verdana" FontSize="14">
                <Grid Background="#FFE5E5E5">
                    <lvc:CartesianChart
                        Series="{Binding SeriesWSE}"
                        XAxes="{Binding XAxesWSE}"
                        YAxes="{Binding YAxesWSE}"
                        x:Name="WSEEmulationChart" 
                        Margin="281,10,10,10" 
                        Background="White" 
                        BorderBrush="Black"
                        ZoomMode="Both"/>
                    <Button 
                        x:Name="DrawGraphButton" 
                        Content="Отобразить график" 
                        HorizontalAlignment="Left" 
                        Margin="10,10,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="151"
                        Command="{Binding DrawGraphCommand}"/>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="10,45,0,10" Width="266" HorizontalAlignment="Left">
                        <DataGrid
                            ItemsSource="{Binding Emulations}"
                            AutoGenerateColumns="False"
                            SelectedItem="{Binding SelectedEmulation}"
                            SelectionMode="Single" 
                            IsReadOnly="True" FontSize="10">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Name"
                                    Binding="{Binding Name}"/>
                                <DataGridTextColumn 
                                    Header="Date"
                                    Binding="{Binding Date}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem x:Name="ModbusSlaveTab" HorizontalAlignment="Center" Height="21" Header="Modbus slave" VerticalAlignment="Top" Width="108" FontFamily="Verdana" FontSize="14" Margin="0,-1,0,0">
                <Grid Background="#FFE5E5E5">
                    <TextBox 
                        x:Name="SlaveIP" 
                        HorizontalAlignment="Left" 
                        Margin="10,40,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <Binding Path="SlaveIP"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:EmulationNameRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBox 
                        x:Name="SlavePort" 
                        HorizontalAlignment="Left" 
                        Margin="10,95,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <Binding Path="SlavePort"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:EmulationNameRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBox 
                        x:Name="SlaveID" 
                        HorizontalAlignment="Left" 
                        Margin="10,150,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <Binding Path="SlaveID"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:EmulationNameRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <Label Content="IP" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="155" FontSize="12"/>
                    <Label Content="Port" HorizontalAlignment="Left" Margin="10,65,0,0" VerticalAlignment="Top" Width="155" FontSize="12"/>
                    <Label Content="SlaveID" HorizontalAlignment="Left" Margin="10,120,0,0" VerticalAlignment="Top" Width="155" FontSize="12"/>
                    <lvc:CartesianChart
                        Series="{Binding SeriesMS}"
                        XAxes="{Binding XAxesMS}"
                        YAxes="{Binding YAxesMS}"
                        x:Name="MSChart" 
                        Margin="185,10,10,252" 
                        Background="White" 
                        BorderBrush="Black"/>
                    <Button 
                        x:Name="StartButton_Copy" 
                        Content="Подключиться" 
                        HorizontalAlignment="Left" 
                        Margin="10,252,0,0" 
                        VerticalAlignment="Top" 
                        Height="30" Width="120" Click="StartButton_Copy_Click"/>
                    <TextBox 
                        x:Name="InputRegisterAddress" 
                        HorizontalAlignment="Left" 
                        Margin="10,227,0,0" 
                        TextWrapping="Wrap" 
                        VerticalAlignment="Top" 
                        Width="147"
                        Validation.ErrorTemplate="{StaticResource validationTemplate}"
                        Validation.Error="PositiveDoubleParse_Error" Height="20">
                        <Binding Path="InputRegisterAddress"
                            NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <rules:EmulationNameRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox>
                    <TextBlock HorizontalAlignment="Left" Margin="10,175,0,0" TextWrapping="Wrap" Text="Адрес Input регистра, откуда брать значения (double) для графика" VerticalAlignment="Top" Height="47" Width="147" FontSize="12"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
